# 풀스택 compose 용 환경변수. 복사해서 사용:
#   cp .env.prod.example .env.prod  &&  편집  &&
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- 데이터베이스 (compose 내부 postgres) ---
POSTGRES_USER=wiki
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=wiki

# --- Keycloak 부트스트랩 관리자 ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-strong
KEYCLOAK_PORT=8080

# --- 앱(Auth.js) ---
# openssl rand -base64 32 로 생성
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=simple-wiki-app
# realm-export.json 의 클라이언트 시크릿(운영은 반드시 교체)
AUTH_KEYCLOAK_SECRET=dev-only-secret
# 브라우저와 앱 컨테이너가 공유하는 issuer 호스트.
# compose 기본값은 http://keycloak:8080/realms/simple-wiki 이며,
# 이 경우 호스트 /etc/hosts 에 "127.0.0.1 keycloak" 한 줄이 필요하다.
AUTH_KEYCLOAK_ISSUER=http://keycloak:8080/realms/simple-wiki
# 지정 시 이 그룹(전체 경로) 소속 사용자도 전역 관리자 (realm 역할 wiki-admin과 병행)
WIKI_ADMIN_GROUP=
APP_PORT=3000

# --- MCP 원격 서버 ---
MCP_PORT=3333
# 공개 노출 시 DNS 리바인딩 보호(쉼표구분 허용 Host). 비우면 비활성.
MCP_ALLOWED_HOSTS=
